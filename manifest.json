{
  "manifest_version": 3,
  "name": "Skychart AI: Super Agente",
  "version": "2.0",
  "description": "Super agente inteligente que detecta componentes PrimeNG e preenche formulários automaticamente.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://app2.skychart.com.br/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app2.skychart.com.br/*"
      ],
      "js": [
        "lib/pdf.min.js",
        "lib/jszip.min.js",
        "debug-panel.js",
        "memory.js",
        "smart-agent.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.worker.min.js",
        "page-inject.js",
        "modules/*.json"
      ],
      "matches": [
        "https://app2.skychart.com.br/*"
      ]
    }
  ]
}