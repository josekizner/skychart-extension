{
  "manifest_version": 3,
  "name": "Atom - Multiagentes | Mond Shipping",
  "version": "2.9",
  "description": "Plataforma de multiagentes inteligentes para automação de processos Mond Shipping.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "debugger",
    "notifications",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "https://app2.skychart.com.br/*",
    "https://generativelanguage.googleapis.com/*",
    "https://www.maersk.com/*",
    "https://server-mond.tail46f98e.ts.net/*",
    "https://docs.google.com/*",
    "https://www.serasaempreendedor.com.br/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.cloud.microsoft/*",
    "https://www.hmm21.com/*",
    "https://mond-atom-default-rtdb.firebaseio.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app2.skychart.com.br/*"
      ],
      "js": [
        "atom-analytics.js",
        "lib/pdf.min.js",
        "lib/jszip.min.js",
        "debug-panel.js",
        "memory.js",
        "smart-agent.js",
        "dom-scanner.js",
        "vision-agent.js",
        "agentic-loop.js",
        "check-agent.js",
        "frequency-agent.js",
        "agenda-agent.js",
        "content.js",
        "health-check.js"
      ],
      "css": [
        "content.css",
        "frequency-agent.css"
      ]
    },
    {
      "matches": [
        "https://www.maersk.com/tracking/*"
      ],
      "js": [
        "atom-analytics.js",
        "maersk-scraper.js"
      ]
    },
    {
      "matches": [
        "https://www.serasaempreendedor.com.br/*"
      ],
      "js": [
        "atom-analytics.js",
        "serasa-consulta.js"
      ]
    },
    {
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.cloud.microsoft/*"
      ],
      "js": [
        "atom-analytics.js",
        "outlook-agent.js",
        "demurrage-agent.js"
      ],
      "css": [
        "outlook-agent.css"
      ]
    },
    {
      "matches": [
        "https://www.hmm21.com/*"
      ],
      "js": [
        "atom-analytics.js",
        "hmm-scraper.js"
      ]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.worker.min.js",
        "page-inject.js",
        "modules/*.json",
        "zechart-logo.png",
        "dashboard.html",
        "dashboard.css",
        "dashboard.js"
      ],
      "matches": [
        "https://app2.skychart.com.br/*"
      ]
    }
  ]
}